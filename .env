# Advanced Coding Tool - 环境变量配置
# ⚠️ 重要：此文件不会提交到 Git 仓库

# AI 提供程序配置
AI_PROVIDER=claude

# 运行模式配置
# auto: 自动检测 (默认，有API密钥用真实模式，没有用模拟模式)
# mock: 强制模拟模式 (安全，无需API密钥)
# real: 强制真实模式 (需要API密钥)
RUN_MODE=mock

# 高级功能开关
ENABLE_ADVANCED_FEATURES=false

# 调试模式
DEBUG_MODE=false

# 日志级别
LOG_LEVEL=info

# API 配置
CLAUDE_MODEL=claude-3-sonnet-20240229
OPENAI_MODEL=gpt-4-turbo-preview
MAX_TOKENS=4000
TEMPERATURE=0.7